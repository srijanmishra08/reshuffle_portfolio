# Portfolio Engine Environment Variables

# Server
PORT=3001
NODE_ENV=development

# YouTube Data API (optional - falls back to oEmbed)
YOUTUBE_API_KEY=

# GitHub API (optional - works without, but rate limited)
GITHUB_TOKEN=

# Storage (local for development)
STORAGE_PATH=./uploads
MAX_FILE_SIZE_MB=100

# Cache TTL (seconds)
YOUTUBE_CACHE_TTL=86400
GITHUB_CACHE_TTL=3600
MEDIA_CACHE_TTL=43200

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_GENERATE_MAX=10

# Security
ALLOWED_ORIGINS=https://reshuffle.app,https://www.reshuffle.app
TRUST_PROXY=false

# oEmbed / Media Resolution
OEMBED_TIMEOUT_MS=8000
MAX_EMBED_RETRIES=2
