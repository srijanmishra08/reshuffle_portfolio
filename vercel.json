{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "view.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/view.html", "dest": "/view.html" },
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/health", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
